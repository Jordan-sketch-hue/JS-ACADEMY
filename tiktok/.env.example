# TikTok Content Posting API — J Supreme Marketing (@jsuprememarketing)
# Copy this to .env and fill in your values

# From TikTok Developer Portal → App Details
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Filled automatically by auth.mjs after OAuth flow
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_TOKEN_EXPIRY=

# Redirect URI registered in your TikTok app
TIKTOK_REDIRECT_URI=http://localhost:3000/callback
